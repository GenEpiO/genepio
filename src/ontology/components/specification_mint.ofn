# Class: obo:GENEPIO_0100000 (RmYN02)

AnnotationAssertion(obo:IAO_0000114 obo:GENEPIO_0100000 "requires discussion")
AnnotationAssertion(obo:IAO_0000115 obo:GENEPIO_0100000 "A severe acute respiratory syndrome-related coronavirus which is 1) bat-derived, 2) sharing 93.3% nucleotide identity with SARS-CoV-2, and 3) contains an insertion at the S1/S2 cleavage site in the spike protein."@en)
AnnotationAssertion(obo:IAO_0000116 obo:GENEPIO_0100000 "Planned Obsolescence: this term is a placeholder for a term requested in another ontology. Once the appropriate ontology term is available, this term’s identifier will be obsoleted with a “term replaced by” id of the other term.")
AnnotationAssertion(obo:IAO_0000119 obo:GENEPIO_0100000 "https://en.wikipedia.org/wiki/RmYN02")
AnnotationAssertion(terms:contributor obo:GENEPIO_0100000 <https://orcid.org/0000-0002-1107-9135>)
AnnotationAssertion(terms:contributor obo:GENEPIO_0100000 <https://orcid.org/0000-0002-8844-9165>)
AnnotationAssertion(terms:contributor obo:GENEPIO_0100000 <https://orcid.org/0000-0002-9578-0788>)
AnnotationAssertion(terms:date obo:GENEPIO_0100000 "2022-01-19T18:23:15.862Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label obo:GENEPIO_0100000 "RmYN02"@en)
SubClassOf(obo:GENEPIO_0100000 obo:NCBITaxon_10239)

# Class: obo:GENEPIO_0100001 (cluster/outbreak investigation sampling)

AnnotationAssertion(obo:IAO_0000114 obo:GENEPIO_0100001 "requires discussion")
AnnotationAssertion(obo:IAO_0000115 obo:GENEPIO_0100001 "A sampling strategy in which individuals are chosen for investigation into a disease cluster or outbreak."@en)
AnnotationAssertion(obo:IAO_0000116 obo:GENEPIO_0100001 "Planned Obsolescence: this term is a placeholder for a term requested in another ontology. Once the appropriate ontology term is available, this term’s identifier will be obsoleted with a “term replaced by” id of the other term.")
AnnotationAssertion(obo:IAO_0000118 obo:GENEPIO_0100001 "Cluster/Outbreak investigation"@en)
AnnotationAssertion(terms:contributor obo:GENEPIO_0100001 <https://orcid.org/0000-0002-1107-9135>)
AnnotationAssertion(terms:contributor obo:GENEPIO_0100001 <https://orcid.org/0000-0002-8844-9165>)
AnnotationAssertion(terms:contributor obo:GENEPIO_0100001 <https://orcid.org/0000-0002-9578-0788>)
AnnotationAssertion(terms:date obo:GENEPIO_0100001 "2022-01-19T18:23:15.862Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:comment obo:GENEPIO_0100001 "The terms cluster and outbreak both describe the occurrence of new disease cases within a particular location and time period. The number of cases within a cluster are not necessarily greater than what is expected, however in an outbreak the number of cases does exceed the usual norm. In an outbreak the cases are confirmed to be epidemiologically linked while in a cluster an epidemiological connection is only suspected. Not all clusters are outbreaks, however each cluster needs to be investigated. [Source: https://covid19evidencereviews.saskhealthauthority.ca/en/permalink/coviddoc153]"@en)
AnnotationAssertion(rdfs:label obo:GENEPIO_0100001 "cluster/outbreak investigation sampling"@en)
SubClassOf(obo:GENEPIO_0100001 obo:HSO_0000072)

# Class: obo:GENEPIO_0100002 (diagnostic testing sampling)

AnnotationAssertion(obo:IAO_0000114 obo:GENEPIO_0100002 "requires discussion")
AnnotationAssertion(obo:IAO_0000115 obo:GENEPIO_0100002 "A sampling strategy in which individuals are sampled in the context of diagnostic testing."@en)
AnnotationAssertion(obo:IAO_0000116 obo:GENEPIO_0100002 "Planned Obsolescence: this term is a placeholder for a term requested in another ontology. Once the appropriate ontology term is available, this term’s identifier will be obsoleted with a “term replaced by” id of the other term.")
AnnotationAssertion(obo:IAO_0000118 obo:GENEPIO_0100002 "Diagnostic testing"@en)
AnnotationAssertion(terms:contributor obo:GENEPIO_0100002 <https://orcid.org/0000-0002-1107-9135>)
AnnotationAssertion(terms:contributor obo:GENEPIO_0100002 <https://orcid.org/0000-0002-8844-9165>)
AnnotationAssertion(terms:contributor obo:GENEPIO_0100002 <https://orcid.org/0000-0002-9578-0788>)
AnnotationAssertion(terms:date obo:GENEPIO_0100002 "2022-01-19T18:23:15.862Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label obo:GENEPIO_0100002 "diagnostic testing sampling"@en)
SubClassOf(obo:GENEPIO_0100002 obo:HSO_0000072)

# Class: obo:GENEPIO_0100003 (research sampling)

