AnnotationAssertion(obo:GENEPIO_0001920 obo:GENEPIO_0001881 "$year/$month/$day")
AnnotationAssertion(obo:GENEPIO_1919 obo:GENEPIO_0001881 "/^(:<year>(19|20)\\d\\d)([- /.])(:<month>0[1-9]|1[012])\\2(:<day>0[1-9]|[12][0-9]|3[01])$/
/^(:<month>0[1-9]|1[012])([- /.])(:<day>0[1-9]|[12][0-9]|3[01])\\2(:<year>(19|20)\\d\\d)$/ 
/^(:<day>0[1-9]|[12][0-9]|3[01])([- /.])(:<month>0[1-9]|1[012])\\2(:<year>(19|20)\\d\\d)$/"^^rdfs:Literal)
AnnotationAssertion(obo:GENEPIO_1921 obo:GENEPIO_0001881 "$year/$month/$day")
AnnotationAssertion(rdfs:comment obo:GENEPIO_0001881 "The instant is subject to the level of granularity of the observed time.  Year / Month / Day / Hour / Minute / Second"@en)
