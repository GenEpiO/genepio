AnnotationAssertion(obo:IAO_0000117 obo:GENEPIO_0002037 "Damion Dooley"@en)
AnnotationAssertion(obo:IAO_0100001 obo:GENEPIO_0002037 "http://purl.obolibrary.org/obo/NCIT_C85539")
AnnotationAssertion(rdfs:label obo:GENEPIO_0002037 "obsolete: antimicrobial resistance phenotype"@en)
AnnotationAssertion(owl:deprecated obo:GENEPIO_0002037 "true"^^xsd:boolean)

# Class: obo:GENEPIO_0002038 (obsolete: antibiotic intermediate resistance (I))

AnnotationAssertion(obo:IAO_0000115 obo:GENEPIO_0002038 "Intermediate resistance indicates that an isolate is observed to offer an intermediate level of resistance to a given antibiotic."@en)
AnnotationAssertion(obo:IAO_0000117 obo:GENEPIO_0002038 "Damion Dooley")
AnnotationAssertion(obo:IAO_0100001 obo:GENEPIO_0002038 "http://purl.obolibrary.org/obo/NCIT_C85560")
AnnotationAssertion(rdfs:label obo:GENEPIO_0002038 "obsolete: antibiotic intermediate resistance (I)"@en)
AnnotationAssertion(owl:deprecated obo:GENEPIO_0002038 "true"^^xsd:boolean)

# Class: obo:GENEPIO_0002039 (obsolete: antibiotic nonsensitive (high resistance))

AnnotationAssertion(obo:IAO_0000115 obo:GENEPIO_0002039 "Non-susceptible indicates that an isolate is observed to offer complete resistance to a given antibiotic."@en)
AnnotationAssertion(obo:IAO_0000117 obo:GENEPIO_0002039 "Damion Dooley")
AnnotationAssertion(obo:IAO_0100001 obo:GENEPIO_0002039 "http://purl.obolibrary.org/obo/NCIT_C85561")
AnnotationAssertion(rdfs:label obo:GENEPIO_0002039 "obsolete: antibiotic nonsensitive (high resistance)"@en)
AnnotationAssertion(owl:deprecated obo:GENEPIO_0002039 "true"^^xsd:boolean)

# Class: obo:GENEPIO_0002041 (obsolete: antibiotic resistant (R))

AnnotationAssertion(obo:IAO_0000115 obo:GENEPIO_0002041 "Resistant indicates that an isolate is observed to offer a greater than intermediate level of resistance to a given antibiotic."@en)
AnnotationAssertion(obo:IAO_0000117 obo:GENEPIO_0002041 "Damion Dooley")
AnnotationAssertion(obo:IAO_0100001 obo:GENEPIO_0002041 "http://purl.obolibrary.org/obo/NCIT_C85562")
