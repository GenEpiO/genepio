AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/GENEPIO_0001400> "2021-04-24T00:42:14Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/GENEPIO_0001400> "signs and symptoms slot"@en)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/GENEPIO_0001400> "Example Guidance: Select all of the symptoms experienced by the host from the pick list."@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/GENEPIO_0001400> "signs and symptoms field"@en)
