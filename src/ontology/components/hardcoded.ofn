# Class: <http://purl.bioontology.org/ontology/MESH/D000830> (animal - laboratory)

AnnotationAssertion(obo:IAO_0000115 <http://purl.bioontology.org/ontology/MESH/D000830> "no definition at source")
AnnotationAssertion(obo:IAO_0000412 <http://purl.bioontology.org/ontology/MESH/D000830> <http://purl.bioontology.org/ontology/MESH>)
AnnotationAssertion(rdfs:label <http://purl.bioontology.org/ontology/MESH/D000830> "animal - laboratory"@en)

# Class: <http://purl.bioontology.org/ontology/MESH/D000835> (animal - wild)

AnnotationAssertion(obo:IAO_0000115 <http://purl.bioontology.org/ontology/MESH/D000835> "Animals considered to be wild or feral or not adapted for domestic use. It does not include wild animals in zoos for which ANIMALS, ZOO is available.")
AnnotationAssertion(obo:IAO_0000412 <http://purl.bioontology.org/ontology/MESH/D000835> <http://purl.bioontology.org/ontology/MESH>)
AnnotationAssertion(rdfs:label <http://purl.bioontology.org/ontology/MESH/D000835> "animal - wild"@en)

# Class: <http://purl.bioontology.org/ontology/MESH/D001482> (base composition)

AnnotationAssertion(obo:IAO_0000115 <http://purl.bioontology.org/ontology/MESH/D001482> "the relative amounts of the purines and pyrimidines in a nucleic acid.")
AnnotationAssertion(obo:IAO_0000412 <http://purl.bioontology.org/ontology/MESH/D001482> <http://purl.bioontology.org/ontology/MESH>)
AnnotationAssertion(oboInOwl:hasExactSynonym <http://purl.bioontology.org/ontology/MESH/D001482> "base composition
base compositions
base ratio
base ratios
gc composition
gc compositions
gc content
gc contents
gc
g+c composition
g+c compositions
g+c content
g+c contents
guanine + cytosine composition
guanine + cytosine content"@en)
AnnotationAssertion(rdfs:label <http://purl.bioontology.org/ontology/MESH/D001482> "base composition"@en)

# Class: <http://purl.bioontology.org/ontology/MESH/D057805> (animal - pet)

AnnotationAssertion(obo:IAO_0000115 <http://purl.bioontology.org/ontology/MESH/D057805> "Animals kept by humans for companionship and enjoyment, as opposed to DOMESTIC ANIMALS such as livestock or farm animals, which are kept for economic reasons.")
AnnotationAssertion(obo:IAO_0000412 <http://purl.bioontology.org/ontology/MESH/D057805> <http://purl.bioontology.org/ontology/MESH>)
AnnotationAssertion(rdfs:label <http://purl.bioontology.org/ontology/MESH/D057805> "animal - pet"@en)

# Class: <http://purl.bioontology.org/ontology/MESH/D058751> (livestock)

AnnotationAssertion(obo:IAO_0000115 <http://purl.bioontology.org/ontology/MESH/D058751> "Domesticated farm animals raised for home use or profit but excluding POULTRY. Typically livestock includes CATTLE; SHEEP; HORSES; SWINE; GOATS; and others.")
AnnotationAssertion(obo:IAO_0000412 <http://purl.bioontology.org/ontology/MESH/D058751> <http://purl.bioontology.org/ontology/MESH>)
AnnotationAssertion(rdfs:label <http://purl.bioontology.org/ontology/MESH/D058751> "livestock"@en)

# Class: obo:CIDO_0000019 (COVID-19 RT-PCR assay)

AnnotationAssertion(obo:IAO_0000117 obo:CIDO_0000019 "A COVID-19 nucleic acid diagnostic assay that uses RT-PCR")
AnnotationAssertion(obo:IAO_0000117 obo:CIDO_0000019 "Oliver He, Asiyah Yu Lin")
AnnotationAssertion(obo:IAO_0000118 obo:CIDO_0000019 "SARS COV-2 RT-PCR")
AnnotationAssertion(obo:IAO_0000119 obo:CIDO_0000019 "https://www.fda.gov/medical-devices/emergency-situations-medical-devices/emergency-use-authorizations#covid19ivd")
AnnotationAssertion(obo:IAO_0000119 obo:CIDO_0000019 "https://www.ncbi.nlm.nih.gov/pmc/articles/PMC7170415/")
AnnotationAssertion(obo:IAO_0000412 obo:CIDO_0000019 obo:cido.owl)
AnnotationAssertion(rdfs:label obo:CIDO_0000019 "COVID-19 RT-PCR assay"@en)
SubClassOf(obo:CIDO_0000019 obo:OBI_0000070)

# Class: obo:CIDO_0000027 (COVID-19 diagnostic process by viral genome sequencing)

AnnotationAssertion(obo:IAO_0000115 obo:CIDO_0000027 "A COVID-19 diagnostic process by viral genome sequencing and identification of the SARS-CoV-2 based on the genome sequence.")
AnnotationAssertion(obo:IAO_0000117 obo:CIDO_0000027 "Oliver He, Asiyah Yu Lin, Hong Yu")
AnnotationAssertion(obo:IAO_0000119 obo:CIDO_0000027 "https://www.ncbi.nlm.nih.gov/pubmed/32245835")
AnnotationAssertion(obo:IAO_0000412 obo:CIDO_0000027 obo:cido.owl)
AnnotationAssertion(rdfs:label obo:CIDO_0000027 "COVID-19 diagnostic process by viral genome sequencing"@en)
SubClassOf(obo:CIDO_0000027 obo:OGMS_0000104)

# Class: obo:CVDO_0000597 (congenital disease)

AnnotationAssertion(obo:IAO_0000115 obo:CVDO_0000597 "A disease existing at birth, or developping during the first month after birth."@en)
AnnotationAssertion(obo:IAO_0000412 obo:CVDO_0000597 obo:cvdo.owl)
AnnotationAssertion(rdfs:label obo:CVDO_0000597 "congenital disease"@en)

# Class: obo:ExO_0000038 (subject health status)

AnnotationAssertion(obo:IAO_0000115 obo:ExO_0000038 "The condition of an organism in all aspects (e.g., functional or metabolic efficiency)."@en)
AnnotationAssertion(obo:IAO_0000116 obo:ExO_0000038 "See technical discussion about logic of assigning health status: 
https://www.w3.org/2001/sw/BestPractices/OEP/Lists-of-values-20040625/"@en)
AnnotationAssertion(oboInOwl:created_by obo:ExO_0000038 "cmattin")
AnnotationAssertion(rdfs:label obo:ExO_0000038 "subject health status"@en)

# Class: obo:FIX_0000278 (redox potential)

AnnotationAssertion(obo:IAO_0000118 obo:FIX_0000278 "E'")
AnnotationAssertion(obo:IAO_0000118 obo:FIX_0000278 "oxidation-reduction potential")
AnnotationAssertion(obo:IAO_0000412 obo:FIX_0000278 obo:fix.owl)
AnnotationAssertion(rdfs:label obo:FIX_0000278 "redox potential")

# Class: obo:GENEPIO_0001744 (0D space)

AnnotationAssertion(rdfs:label obo:GENEPIO_0001744 "0D space"@en)
SubClassOf(obo:GENEPIO_0001744 obo:GENEPIO_0001854)

# Class: obo:GENEPIO_0001854 (n-dimensional space)

AnnotationAssertion(rdfs:comment obo:GENEPIO_0001854 "An N-dimensional space consists of n dimensions, each with an origin.  It can be translated via various coordinate systems, and can be populated with N and lesser dimensional vectors."@en)
AnnotationAssertion(rdfs:label obo:GENEPIO_0001854 "n-dimensional space"@en)
SubClassOf(obo:GENEPIO_0001854 obo:GENEPIO_0001859)

# Class: obo:GENEPIO_0001855 (1D space)

AnnotationAssertion(rdfs:comment obo:GENEPIO_0001855 "A distance metric exists between any two members of a one-dimensional set.
Should have vector as subclass?"@en)
AnnotationAssertion(rdfs:label obo:GENEPIO_0001855 "1D space"@en)
SubClassOf(obo:GENEPIO_0001855 obo:GENEPIO_0001854)
SubClassOf(obo:GENEPIO_0001855 ObjectSomeValuesFrom(obo:BFO_0000051 obo:GENEPIO_0001864))

# Class: obo:GENEPIO_0001856 (2D space)

AnnotationAssertion(obo:IAO_0000115 obo:GENEPIO_0001856 "This data type is for an item that can map to a point, line, set or area on a surface (2 dimensional space) or to the surface itself.  It can be a slice of a higher dimensional space.

It can be defined by a cartesian or radial coordinate system."@en)
AnnotationAssertion(rdfs:label obo:GENEPIO_0001856 "2D space"@en)
SubClassOf(obo:GENEPIO_0001856 obo:GENEPIO_0001854)
SubClassOf(obo:GENEPIO_0001856 ObjectSomeValuesFrom(obo:BFO_0000051 obo:GENEPIO_0001865))

# Class: obo:GENEPIO_0001857 (3D space)

AnnotationAssertion(rdfs:label obo:GENEPIO_0001857 "3D space"@en)
SubClassOf(obo:GENEPIO_0001857 obo:GENEPIO_0001854)
SubClassOf(obo:GENEPIO_0001857 ObjectSomeValuesFrom(obo:BFO_0000051 obo:GENEPIO_0001866))

# Class: obo:GENEPIO_0001858 (n-dimensional coordinate)

AnnotationAssertion(rdfs:label obo:GENEPIO_0001858 "n-dimensional coordinate"@en)
SubClassOf(obo:GENEPIO_0001858 obo:GENEPIO_0001859)

# Class: obo:GENEPIO_0001859 (n-dimensional concept)

AnnotationAssertion(rdfs:label obo:GENEPIO_0001859 "n-dimensional concept"@en)

# Class: obo:GENEPIO_0001860 (1D coordinate)

AnnotationAssertion(rdfs:comment obo:GENEPIO_0001860 "This should cover all interval data"@en)
AnnotationAssertion(rdfs:label obo:GENEPIO_0001860 "1D coordinate"@en)
SubClassOf(obo:GENEPIO_0001860 obo:GENEPIO_0001858)
SubClassOf(obo:GENEPIO_0001860 ObjectExactCardinality(1 obo:RO_0002180 obo:GENEPIO_0001864))
SubClassOf(obo:GENEPIO_0001860 ObjectExactCardinality(1 obo:RO_0002180 obo:GENEPIO_0001919))

# Class: obo:GENEPIO_0001861 (2D coordinate)

AnnotationAssertion(rdfs:label obo:GENEPIO_0001861 "2D coordinate"@en)
SubClassOf(obo:GENEPIO_0001861 obo:GENEPIO_0001858)
SubClassOf(obo:GENEPIO_0001861 ObjectExactCardinality(2 obo:RO_0002180 obo:GENEPIO_0001860))

# Class: obo:GENEPIO_0001862 (latitude specification (ISO 6709))

AnnotationAssertion(rdfs:label obo:GENEPIO_0001862 "latitude specification (ISO 6709)"@en)
SubClassOf(obo:GENEPIO_0001862 ObjectSomeValuesFrom(obo:IAO_0000039 obo:UO_0000185))
SubClassOf(obo:GENEPIO_0001862 DataSomeValuesFrom(obo:OBI_0002135 DatatypeRestriction(xsd:decimal xsd:minInclusive "-90.0"^^xsd:decimal xsd:maxInclusive "90.0"^^xsd:decimal)))

# Class: obo:GENEPIO_0001863 (longitude specification (ISO 6709))

AnnotationAssertion(rdfs:label obo:GENEPIO_0001863 "longitude specification (ISO 6709)"@en)
SubClassOf(obo:GENEPIO_0001863 ObjectSomeValuesFrom(obo:IAO_0000039 obo:UO_0000185))
SubClassOf(obo:GENEPIO_0001863 DataSomeValuesFrom(obo:OBI_0002135 DatatypeRestriction(xsd:decimal xsd:minInclusive "-180.0"^^xsd:decimal xsd:maxInclusive "180.0"^^xsd:decimal)))

# Class: obo:GENEPIO_0001864 (1D coordinate system)

AnnotationAssertion(rdfs:label obo:GENEPIO_0001864 "1D coordinate system"@en)
SubClassOf(obo:GENEPIO_0001864 obo:STATO_0000010)
SubClassOf(obo:GENEPIO_0001864 ObjectExactCardinality(1 obo:RO_0002180 obo:UO_0000000))

# Class: obo:GENEPIO_0001865 (2D coordinate system)

AnnotationAssertion(rdfs:label obo:GENEPIO_0001865 "2D coordinate system"@en)
SubClassOf(obo:GENEPIO_0001865 obo:STATO_0000010)
SubClassOf(obo:GENEPIO_0001865 ObjectExactCardinality(2 obo:RO_0002180 obo:GENEPIO_0001864))

# Class: obo:GENEPIO_0001866 (3D coordinate system)

AnnotationAssertion(rdfs:label obo:GENEPIO_0001866 "3D coordinate system"@en)
SubClassOf(obo:GENEPIO_0001866 obo:STATO_0000010)
SubClassOf(obo:GENEPIO_0001866 ObjectExactCardinality(3 obo:RO_0002180 obo:GENEPIO_0001864))

# Class: obo:GENEPIO_0001867 (radial coordinate system)

AnnotationAssertion(rdfs:comment obo:GENEPIO_0001867 "A coordinate system composed of a radius from the origin of one dimension combined with angular offsets from the origins of the remaining dimensions."@en)
AnnotationAssertion(rdfs:label obo:GENEPIO_0001867 "radial coordinate system"@en)
SubClassOf(obo:GENEPIO_0001867 obo:STATO_0000010)
SubClassOf(obo:GENEPIO_0001867 ObjectMinCardinality(1 obo:RO_0002180 obo:GENEPIO_0001868))
SubClassOf(obo:GENEPIO_0001867 ObjectExactCardinality(1 obo:RO_0002180 obo:PATO_0002390))

# Class: obo:GENEPIO_0001868 (angular coordinate)

AnnotationAssertion(rdfs:label obo:GENEPIO_0001868 "angular coordinate"@en)
SubClassOf(obo:GENEPIO_0001868 obo:GENEPIO_0001860)
SubClassOf(obo:GENEPIO_0001868 ObjectExactCardinality(1 obo:IAO_0000039 obo:UO_0000121))

# Class: obo:GENEPIO_0001869 (linear coordinate)

AnnotationAssertion(rdfs:comment obo:GENEPIO_0001869 "A coordinate composed of a given dimension and the offset from the origin of the dimension to some point"@en)
AnnotationAssertion(rdfs:label obo:GENEPIO_0001869 "linear coordinate"@en)
SubClassOf(obo:GENEPIO_0001869 obo:GENEPIO_0001860)
SubClassOf(obo:GENEPIO_0001869 ObjectExactCardinality(1 obo:RO_0002180 obo:UO_0000001))

# Class: obo:GENEPIO_0001870 (area calculation)

AnnotationAssertion(obo:IAO_0000115 obo:GENEPIO_0001870 "An area calculation datum is a functional mapping of a two dimensional surface area (can be anything from an abstract polygon, to a postal code or country) to a 1 dimensional scalar.  The original surface area may be curved, e.g. spheroid.  The surface area can also be described using only one input - for example the radius scalar of a polar coordinate plane described by pi*r^2."@en)
AnnotationAssertion(rdfs:label obo:GENEPIO_0001870 "area calculation"@en)
SubClassOf(obo:GENEPIO_0001870 obo:GENEPIO_0001869)
SubClassOf(obo:GENEPIO_0001870 ObjectExactCardinality(1 obo:RO_0002180 obo:GENEPIO_0001908))

# Class: obo:GENEPIO_0001871 (geographic coordinate)

AnnotationAssertion(rdfs:label obo:GENEPIO_0001871 "geographic coordinate"@en)
SubClassOf(obo:GENEPIO_0001871 obo:GENEPIO_0001861)
SubClassOf(obo:GENEPIO_0001871 ObjectExactCardinality(1 obo:RO_0002180 obo:GEO_000000788))
SubClassOf(obo:GENEPIO_0001871 ObjectExactCardinality(1 obo:RO_0002180 obo:OBI_0001620))
SubClassOf(obo:GENEPIO_0001871 ObjectExactCardinality(1 obo:RO_0002180 obo:OBI_0001621))

# Class: obo:GENEPIO_0001872 (removed date)

AnnotationAssertion(rdfs:label obo:GENEPIO_0001872 "removed date"@en)
SubClassOf(obo:GENEPIO_0001872 obo:GENEPIO_0001883)

