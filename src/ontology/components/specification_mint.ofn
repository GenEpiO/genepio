AnnotationAssertion(terms:date obo:GENEPIO_0100279 "2022-01-19T18:23:15.862Z"^^xsd:dateTime)
AnnotationAssertion(oboInOwl:hasExactSynonym obo:GENEPIO_0100279 "VBM"@en)
AnnotationAssertion(oboInOwl:hasExactSynonym obo:GENEPIO_0100279 "VUM"@en)
AnnotationAssertion(oboInOwl:hasExactSynonym obo:GENEPIO_0100279 "Variant Being Monitored"@en)
AnnotationAssertion(rdfs:comment obo:GENEPIO_0100279 "PHA4GE Definition: A category used for indicating that a variant of the Severe Acute Respiratory Syndrome Coronavirus 2 (SARS-CoV-2) containing genetic mutations that may increase binding affinity to human cells and linked to rapid spread in human populations is being monitored. This category denotes less risk than a Variant of Interest (VOI)."@en)
AnnotationAssertion(rdfs:label obo:GENEPIO_0100279 "variant under monitoring (SARS-CoV-2)"@en)
