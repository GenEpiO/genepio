AnnotationAssertion(obo:IAO_0000119 obo:GENEPIO_0002137 "Emma Griffiths")
AnnotationAssertion(obo:IAO_0000233 obo:GENEPIO_0002137 "https://github.com/obi-ontology/obi/issues/1579")
AnnotationAssertion(oboInOwl:hasDbXref obo:GENEPIO_0002137 obo:OBI_0002879)
AnnotationAssertion(rdfs:label obo:GENEPIO_0002137 "breadth of coverage")
SubClassOf(obo:GENEPIO_0002137 obo:OBI_0000973)

