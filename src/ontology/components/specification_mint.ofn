AnnotationAssertion(oboInOwl:hasExactSynonym obo:GENEPIO_0100089 "complete Kawasaki syndrome"@en)
AnnotationAssertion(rdfs:label obo:GENEPIO_0100089 "complete Kawasaki disease"@en)
SubClassOf(obo:GENEPIO_0100089 obo:DOID_114)

