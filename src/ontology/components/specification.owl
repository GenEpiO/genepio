# Class: <http://purl.obolibrary.org/obo/GENEPIO_0102187> (18S ribosomal gene sequencing assay)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/GENEPIO_0102187> "An amplicon sequencing assay in which the amplicon is derived from universal primers used to amplify the 18S ribosomal RNA gene from isolate bacterial genomic DNA or metagenomic DNA from a microbioal community. Resulting sequences are compared to reference 18S sequence databases to identify or classify bacteria present within a given sample."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> <http://purl.obolibrary.org/obo/GENEPIO_0102187> "Planned Obsolescence: this term is a placeholder for a term requested in another ontology. Once the appropriate ontology term is available, this term’s identifier will be obsoleted with a “term replaced by” id of the other term.")
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/GENEPIO_0102187> "2026-04-13T19:52:38.515Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/GENEPIO_0102187> "18S ribosomal gene sequencing assay"@en)
SubClassOf(<http://purl.obolibrary.org/obo/GENEPIO_0102187> <http://purl.obolibrary.org/obo/OBI_0002767>)

# Class: <http://purl.obolibrary.org/obo/GENEPIO_0102188> (Viral amplicon sequencing)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/GENEPIO_0102188> "An amplicon sequencing assay in which one or more genomic regions of viral nucleic acids are selectively amplified using PCR and subsequently sequenced to detect, characterise, or quantify viral populations"@en)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/GENEPIO_0102188> "2026-04-13T19:52:38.515Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/GENEPIO_0102188> "Viral amplicon sequencing"@en)
SubClassOf(<http://purl.obolibrary.org/obo/GENEPIO_0102188> <http://purl.obolibrary.org/obo/OBI_0002767>)

# Class: <http://purl.obolibrary.org/obo/GENEPIO_0102189> (Cytochrome c oxidase I barcoding)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/GENEPIO_0102189> "An amplicon sequencing assay that targets and sequences a standardized region of the mitochondrial cytochrome c oxidase subunit I (COI) gene to enable taxonomic identification of eukaryotic organisms based on DNA barcodes."@en)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/GENEPIO_0102189> "2026-04-13T19:52:38.515Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/GENEPIO_0102189> "Cytochrome c oxidase I barcoding"@en)
SubClassOf(<http://purl.obolibrary.org/obo/GENEPIO_0102189> <http://purl.obolibrary.org/obo/OBI_0002767>)

# Class: <http://purl.obolibrary.org/obo/GENEPIO_0102190> (Magnetic bead capture)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/GENEPIO_0102190> "A library selection process in which target molecules are selectively bound to magnetic beads and separated from a sample using a magnetic field."@en)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/GENEPIO_0102190> "2026-04-13T19:52:38.515Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/GENEPIO_0102190> "Magnetic bead capture"@en)
SubClassOf(<http://purl.obolibrary.org/obo/GENEPIO_0102190> <http://purl.obolibrary.org/obo/GENEPIO_0001940>)

# Class: <http://purl.obolibrary.org/obo/GENEPIO_0102191> (Poly(A) selection)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/GENEPIO_0102191> "A library selection process in which polyadenylated RNA molecules are selectively captured from a sample, typically using oligo(dT) probes, to enrich for messenger RNA."@en)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/GENEPIO_0102191> "2026-04-13T19:52:38.515Z"^^xsd:dateTime)
